# EditorConfig for PowerShell Package

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.ts]
indent_size = 2

[*.json]
indent_size = 2

[*.ps1]
indent_size = 4
indent_style = space

[*.psm1]
indent_size = 4
indent_style = space

[*.psd1]
indent_size = 4
indent_style = space

[*.md]
trim_trailing_whitespace = false
