{
  "name": "ark-format-powershell",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.2.2",
  "publisher": "tooark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tooark/vscode-ark-format.git",
    "directory": "packages/powershell"
  },
  "homepage": "https://github.com/Tooark/vscode-ark-format/tree/main/packages/powershell",
  "bugs": {
    "url": "https://github.com/Tooark/vscode-ark-format/issues"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/paulosfjunior"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "assets/icon.png",
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "formatter",
    "powershell",
    "ps1",
    "tooark"
  ],
  "activationEvents": [
    "onLanguage:powershell"
  ],
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "arkFormatPowerShell.enabled": {
          "type": "boolean",
          "default": true,
          "order": 1,
          "description": "%config.enabled.description%"
        },
        "arkFormatPowerShell.effectLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "powershell"
          ],
          "order": 2,
          "description": "%config.effectLanguages.description%"
        },
        "arkFormatPowerShell.useEditorConfig": {
          "type": "boolean",
          "default": false,
          "order": 3,
          "description": "%config.useEditorConfig.description%"
        },
        "arkFormatPowerShell.indentStyle": {
          "type": "string",
          "default": "space",
          "enum": [
            "space",
            "tab"
          ],
          "order": 10,
          "description": "%config.indentStyle.description%"
        },
        "arkFormatPowerShell.indentSize": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "order": 11,
          "description": "%config.indentSize.description%"
        },
        "arkFormatPowerShell.lineEnding": {
          "type": "string",
          "default": "CRLF",
          "enum": [
            "LF",
            "CRLF",
            "Auto"
          ],
          "order": 12,
          "description": "%config.lineEnding.description%"
        },
        "arkFormatPowerShell.trimTrailingWhitespace": {
          "type": "boolean",
          "default": true,
          "order": 13,
          "description": "%config.trimTrailingWhitespace.description%"
        },
        "arkFormatPowerShell.maxConsecutiveBlankLines": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "order": 14,
          "description": "%config.maxConsecutiveBlankLines.description%"
        },
        "arkFormatPowerShell.removeLeadingBlankLines": {
          "type": "boolean",
          "default": true,
          "order": 15,
          "description": "%config.removeLeadingBlankLines.description%"
        },
        "arkFormatPowerShell.insertFinalNewline": {
          "type": "boolean",
          "default": true,
          "order": 16,
          "description": "%config.insertFinalNewline.description%"
        },
        "arkFormatPowerShell.collapseSpaces": {
          "type": "boolean",
          "default": true,
          "order": 17,
          "description": "%config.collapseSpaces.description%"
        },
        "arkFormatPowerShell.formatBlockComments": {
          "type": "boolean",
          "default": false,
          "order": 18,
          "description": "%config.formatBlockComments.description%"
        },
        "arkFormatPowerShell.alignAssignments": {
          "type": "boolean",
          "default": false,
          "order": 19,
          "description": "%config.alignAssignments.description%"
        },
        "arkFormatPowerShell.rangeFormatting.enabled": {
          "type": "boolean",
          "default": true,
          "order": 20,
          "description": "%config.rangeFormatting.enabled.description%"
        },
        "arkFormatPowerShell.rangeFormatting.reindent": {
          "type": "boolean",
          "default": false,
          "order": 21,
          "description": "%config.rangeFormatting.reindent.description%"
        },
        "arkFormatPowerShell.rangeFormatting.useDocumentContext": {
          "type": "boolean",
          "default": true,
          "order": 22,
          "description": "%config.rangeFormatting.useDocumentContext.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm --filter @tooark/ark-format-shared build && node ./esbuild.mjs --production",
    "watch": "pnpm --filter @tooark/ark-format-shared build && node ./esbuild.mjs --watch",
    "compile": "pnpm --filter @tooark/ark-format-shared build && node ./esbuild.mjs",
    "lint": "pnpm exec eslint src",
    "vscode:prepublish": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "pnpm exec vsce package --no-dependencies",
    "publish": "pnpm exec vsce publish --no-dependencies"
  },
  "dependencies": {
    "@tooark/ark-format-shared": "workspace:*"
  }
}
