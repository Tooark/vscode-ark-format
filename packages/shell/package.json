{
  "name": "ark-format-shell",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.0.0",
  "publisher": "tooark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tooark/vscode-ark-format/packages/shell"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "formatter",
    "shell",
    "bash",
    "esbuild",
    "pnpm",
    "tooark"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "onLanguage:azcli",
    "onLanguage:bash",
    "onLanguage:bats",
    "onLanguage:ksh",
    "onLanguage:sh",
    "onLanguage:sh.posix",
    "onLanguage:shellscript",
    "onLanguage:tcsh"
  ],
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "azcli",
        "extensions": [
          ".azcli"
        ],
        "aliases": [
          "Azure CLI"
        ]
      },
      {
        "id": "bash",
        "extensions": [
          ".bash"
        ],
        "aliases": [
          "Bash"
        ]
      },
      {
        "id": "bats",
        "extensions": [
          ".bats"
        ],
        "aliases": [
          "Bats"
        ]
      },
      {
        "id": "ksh",
        "extensions": [
          ".ksh"
        ],
        "aliases": [
          "KornShell"
        ]
      },
      {
        "id": "sh",
        "extensions": [
          ".sh"
        ],
        "aliases": [
          "Shell"
        ]
      },
      {
        "id": "sh.posix",
        "extensions": [
          ".sh.posix"
        ],
        "aliases": [
          "POSIX Shell"
        ]
      },
      {
        "id": "tcsh",
        "extensions": [
          ".tcsh"
        ],
        "aliases": [
          "Tcsh"
        ]
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "arkFormatShell.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.enabled.description%"
        },
        "arkFormatShell.effectLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "azcli",
            "bash",
            "bats",
            "ksh",
            "sh",
            "sh.posix",
            "shellscript",
            "tcsh"
          ],
          "description": "%config.effectLanguages.description%"
        },
        "arkFormatShell.useEditorConfig": {
          "type": "boolean",
          "default": false,
          "description": "%config.useEditorConfig.description%"
        },
        "arkFormatShell.engine": {
          "type": "string",
          "default": "internal",
          "enum": [
            "internal",
            "shfmt"
          ],
          "enumDescriptions": [
            "%config.engine.enum.internal%",
            "%config.engine.enum.shfmt%"
          ],
          "description": "%config.engine.description%"
        },
        "arkFormatShell.shfmt.path": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%config.shfmt.path.description%"
        },
        "arkFormatShell.shfmt.flags": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%config.shfmt.flags.description%"
        },
        "arkFormatShell.indentStyle": {
          "type": "string",
          "default": "space",
          "enum": [
            "space",
            "tab"
          ],
          "description": "%config.indentStyle.description%"
        },
        "arkFormatShell.indentSize": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "%config.indentSize.description%"
        },
        "arkFormatShell.lineEnding": {
          "type": "string",
          "default": "LF",
          "enum": [
            "LF",
            "CRLF",
            "Auto"
          ],
          "description": "%config.lineEnding.description%"
        },
        "arkFormatShell.trimTrailingWhitespace": {
          "type": "boolean",
          "default": true,
          "description": "%config.trimTrailingWhitespace.description%"
        },
        "arkFormatShell.maxConsecutiveBlankLines": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "description": "%config.maxConsecutiveBlankLines.description%"
        },
        "arkFormatShell.removeLeadingBlankLines": {
          "type": "boolean",
          "default": true,
          "description": "%config.removeLeadingBlankLines.description%"
        },
        "arkFormatShell.insertFinalNewline": {
          "type": "boolean",
          "default": true,
          "description": "%config.insertFinalNewline.description%"
        },
        "arkFormatShell.collapseSpaces": {
          "type": "boolean",
          "default": true,
          "description": "%config.collapseSpaces.description%"
        },
        "arkFormatShell.spacing.spaceBeforeThenDo": {
          "type": "boolean",
          "default": true,
          "description": "%config.spacing.spaceBeforeThenDo.description%"
        },
        "arkFormatShell.spacing.spaceAfterKeywords": {
          "type": "boolean",
          "default": true,
          "description": "%config.spacing.spaceAfterKeywords.description%"
        },
        "arkFormatShell.spacing.spaceBeforeFunctionBrace": {
          "type": "boolean",
          "default": true,
          "description": "%config.spacing.spaceBeforeFunctionBrace.description%"
        },
        "arkFormatShell.rangeFormatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.rangeFormatting.enabled.description%"
        },
        "arkFormatShell.rangeFormatting.reindent": {
          "type": "boolean",
          "default": false,
          "description": "%config.rangeFormatting.reindent.description%"
        },
        "arkFormatShell.rangeFormatting.useDocumentContext": {
          "type": "boolean",
          "default": true,
          "description": "%config.rangeFormatting.useDocumentContext.description%"
        }
      }
    },
    "commands": [
      {
        "command": "arkFormatShell.formatDocument",
        "title": "%command.formatDocument%"
      },
      {
        "command": "arkFormatShell.formatSelection",
        "title": "%command.formatSelection%"
      }
    ]
  },
  "scripts": {
    "build": "pnpm --filter @tooark/ark-format-shared build && node ./esbuild.mjs --production",
    "watch": "pnpm --filter @tooark/ark-format-shared build && node ./esbuild.mjs --watch",
    "compile": "pnpm --filter @tooark/ark-format-shared build && node ./esbuild.mjs",
    "lint": "pnpm exec eslint src",
    "vscode:prepublish": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "pnpm exec vsce package --no-dependencies",
    "publish": "pnpm exec vsce publish --no-dependencies"
  },
  "dependencies": {
    "@tooark/ark-format-shared": "workspace:*"
  }
}
