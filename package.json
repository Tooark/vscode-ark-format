{
  "name": "vscode-ark-format",
  "description": "Monorepo das extensões VS Code Ark Format (Shell, PowerShell e Makefile).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tooark/vscode-ark-format.git"
  },
  "homepage": "https://github.com/Tooark/vscode-ark-format",
  "bugs": {
    "url": "https://github.com/Tooark/vscode-ark-format/issues"
  },
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "watch": "pnpm -r --parallel --if-present watch",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "pnpm -r --parallel --if-present test:watch",
    "package": "pnpm -r --if-present package"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
